# --- DEPENDENCIES ---
# Never push these. Vercel runs 'npm install' to create its own.
node_modules/
.pnp
.pnp.js

# --- NEXT.JS BUILD OUTPUT ---
# These are generated during 'npm run build'. 
# Vercel creates these on its servers, so your local ones are not needed.
.next/
out/
build/

# --- ENVIRONMENT VARIABLES ---
# CRITICAL: This prevents your private API keys from being public on GitHub.
# You will add these keys manually in the Vercel Dashboard instead.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- DEBUG & LOGS ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- SYSTEM FILES ---
# Keeps your repo clean of OS-specific metadata
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# --- VERCEL SPECIFIC ---
# Hidden folder created if you use the Vercel CLI locally
.vercel